<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#FF1A1A1A">

	<LinearLayout
		android:id="@+id/header_ch"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
		android:layout_gravity="center"
		android:background="#FF3A3A3A"
		android:paddingLeft="10dp"
		android:paddingRight="10dp"
		android:paddingTop="8dp"
		android:paddingBottom="8dp">

		<TextView
			android:id="@+id/header_txt"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="选择目录"
			android:textColor="#FFFFFF"
			android:textSize="16sp"
			android:textStyle="bold" />
	</LinearLayout>

	<LinearLayout
		android:id="@+id/footer2"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_alignParentBottom="true"
		android:background="#FF3A3A3A"
		android:orientation="horizontal">

		<Button
			android:id="@+id/button_choice"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="@string/srceng_dir_choice_btn"
			android:textColor="#FFFFFF"
			android:textStyle="bold" />
	</LinearLayout>

	<!-- Main content area with left-right structure -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_above="@+id/footer2"
		android:layout_below="@+id/header_ch"
		android:orientation="horizontal"
		android:paddingTop="5dp"
		android:paddingBottom="5dp">

		<!-- Left panel - Directory list -->
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_weight="1.2"
			android:background="#FF2A2A2A"
			android:orientation="vertical"
			android:paddingLeft="2dp"
			android:paddingTop="1dp"
			android:paddingRight="2dp"
			android:paddingBottom="1dp">

			<ScrollView
				android:layout_width="fill_parent"
				android:layout_height="fill_parent"
				android:fillViewport="true">

				<LinearLayout
					android:id="@+id/bodych"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:background="#FF3A3A3A"
					android:orientation="vertical"
					android:padding="5dp">
			    </LinearLayout>
			</ScrollView>
		</LinearLayout>

		<!-- Right panel - Information and current path -->
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_weight="0.8"
			android:background="#FF353535"
			android:orientation="vertical"
			android:padding="15dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#FF212121"
				android:orientation="vertical"
				android:padding="15dp">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="当前路径"
					android:textColor="#FFFFFF"
					android:textSize="16sp"
					android:textStyle="bold"
					android:layout_marginBottom="10dp" />

				<TextView
					android:id="@+id/current_path_info"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="未选择"
					android:textColor="#CCCCCC"
					android:textSize="12sp"
					android:layout_marginBottom="20dp" />

				<View
					android:layout_width="match_parent"
					android:layout_height="1dp"
					android:background="#FF3A3A3A"
					android:layout_marginBottom="20dp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="操作说明"
					android:textColor="#FFFFFF"
					android:textSize="16sp"
					android:textStyle="bold"
					android:layout_marginBottom="10dp" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"			
					android:textColor="#CCCCCC"
					android:textSize="12sp"
					android:lineSpacingExtra="3dp" />

			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</RelativeLayout>