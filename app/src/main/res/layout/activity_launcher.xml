<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#FF252525">

	<LinearLayout
		android:id="@+id/header"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_alignParentTop="true"
		android:layout_gravity="center"
		android:background="#FF3A3A3A"
		android:gravity="center"
		android:paddingLeft="10dp">

		<include
			android:layout_width="48dp"
			android:layout_height="48dp"
			layout="@layout/logo" />

		<TextView
			android:id="@+id/header_text"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/mod_name"
			android:textColor="#FFFFFF"
			android:textSize="25sp" />
	</LinearLayout>

	<LinearLayout
		android:id="@+id/footer"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_alignParentBottom="true"
		android:background="#FF3A3A3A"
		android:orientation="horizontal">

		<Button
			android:id="@+id/button_about"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="@string/srceng_launcher_about_title"
			android:textColor="#FFFFFF" />

		<Button
			android:id="@+id/button_launch"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="@string/srceng_launcher_launch"
			android:textColor="#FFFFFF" />
	</LinearLayout>

	<!-- Main content area with left-right structure -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_above="@+id/footer"
		android:layout_below="@+id/header"
		android:orientation="horizontal"
		android:paddingTop="5dp"
		android:paddingBottom="5dp">

		<!-- Left panel -->
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_weight="1"
			android:background="#FF353535"
			android:gravity="center"
			android:orientation="vertical"
			android:padding="20dp">

			<!-- Game logo or icon can be placed here -->
			<ImageView
				android:layout_width="120dp"
				android:layout_height="120dp"
				android:layout_marginBottom="20dp"
				android:background="@drawable/csso_icon" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="CS:SO"
				android:textColor="#FFFFFF"
				android:textSize="24sp"
				android:textStyle="bold" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="10dp"
				android:text="Counter-Strike: Source Offensive"
				android:textColor="#CCCCCC"
				android:textSize="14sp" />

		</LinearLayout>

		<!-- Right panel - Settings -->
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_weight="1.5"
			android:background="#FF353535"
			android:orientation="vertical"
			android:paddingLeft="10dp"
			android:paddingTop="10dp"
			android:paddingRight="10dp"
			android:paddingBottom="10dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#FF212121"
				android:orientation="vertical"
				android:paddingLeft="10dp"
				android:paddingTop="10dp"
				android:paddingRight="10dp"
				android:paddingBottom="10dp">

				<ScrollView
					android:layout_width="fill_parent"
					android:layout_height="fill_parent"
					android:fillViewport="true">

					<LinearLayout
						android:id="@+id/body"
						android:layout_width="fill_parent"
						android:layout_height="wrap_content"
						android:background="#FF313131"
						android:orientation="vertical"
						android:padding="10dp">

						<!-- Command line args -->
						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginLeft="5dp"
							android:layout_marginRight="5dp"
							android:text="@string/srceng_launcher_command_args"
							android:textAppearance="?android:attr/textAppearanceMedium"
							android:textColor="#FFFFFF" />

						<EditText
							android:id="@+id/edit_cmdline"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginLeft="3dp"
							android:layout_marginRight="3dp"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="15dp"
							android:backgroundTint="@color/hl_color"
							android:inputType="text"
							android:maxLines="1"
							android:text="@string/default_commandline_arguments"
							android:autofillHints=""
							android:textColor="#FFFFFF"
							tools:ignore="LabelFor" />

						<!-- Game resources -->
						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginLeft="5dp"
							android:layout_marginRight="5dp"
							android:text="@string/srceng_launcher_game_path"
							android:textAppearance="?android:attr/textAppearanceMedium"
							android:textColor="#FFFFFF" />

						<EditText
							android:id="@+id/edit_gamepath"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginLeft="3dp"
							android:layout_marginRight="3dp"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:backgroundTint="@color/hl_color"
							android:inputType="text"
							android:maxLines="1"
							android:text="@string/default_gamedir"
							android:autofillHints=""
							android:textColor="#FFFFFF"
							tools:ignore="LabelFor" />

						<Button
							android:id="@+id/button_gamedir"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/srceng_launcher_set_game_path"
							android:layout_marginLeft="3dp"
							android:layout_marginRight="3dp"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:textColor="#FFFFFF" />
					</LinearLayout>
				</ScrollView>
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</RelativeLayout>